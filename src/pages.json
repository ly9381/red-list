{
  "globalStyle": {
    "navigationStyle": "default",
    "navigationBarTitleText": "unibest",
    "navigationBarBackgroundColor": "#f8f8f8",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#FFFFFF"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^fg-(.*)": "@/components/fg-$1/fg-$1.vue",
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue",
      "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue"
    }
  },
  "tabBar": {
    "custom": false,
    "color": "#5F6672",
    "selectedColor": "#F32626",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "height": "58px",
    "fontSize": "11px",
    "iconWidth": "30px",
    "spacing": "2px",
    "list": [
      {
        "iconPath": "static/tabbar/tab-home.png",
        "selectedIconPath": "static/tabbar/tab-home-active.png",
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "iconPath": "static/tabbar/tab-rank.png",
        "selectedIconPath": "static/tabbar/tab-rank-active.png",
        "pagePath": "pages/list/list",
        "text": "榜单"
      },
      {
        "iconPath": "static/tabbar/tab-report.png",
        "selectedIconPath": "static/tabbar/tab-report-active.png",
        "pagePath": "pages/report/report",
        "text": "上报"
      },
      {
        "iconPath": "static/tabbar/tab-my.png",
        "selectedIconPath": "static/tabbar/tab-my-active.png",
        "pagePath": "pages/my/my",
        "text": "我的"
      }
    ]
  },
  "pages": [
    {
      "path": "pages/index/index",
      "type": "home",
      "layout": "tabbar",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/list/list",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "榜单",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/login/login",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "海星优家",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/my/my",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/report/report",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "上报"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub",
      "pages": [
        {
          "path": "demo/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "分包页面"
          }
        },
        {
          "path": "merchant_detail/detail",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "点评详情"
          }
        },
        {
          "path": "recordlist/recordlist",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "全部上传记录"
          }
        },
        {
          "path": "redmerchant/redmerchant",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "全部榜单商家"
          }
        },
        {
          "path": "update/update",
          "type": "page"
        }
      ]
    }
  ]
}